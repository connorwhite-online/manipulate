    "lint": "next lint"
  },
  "dependencies": {
    "@manipulate/hand": "*",
    "@react-three/drei": "^10.6.1",
    "@react-three/fiber": "^9.3.0","next": "^15.4.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "three": "^0.179.1"
  },
  "devDependencies": {
    "@types/node": "24.3.0",
    "eslint": "^9.9.0",
    "eslint-config-next": "^15.0.0"
  }
}
